# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/chatbot  # MongoDB connection string
MONGO_USERNAME=                     # MongoDB username
MONGO_PASSWORD=                     # MongoDB password
MONGO_DATABASE=langchain_bot        # MongoDB database name
